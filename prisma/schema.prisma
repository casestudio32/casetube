// Prisma Schema — defines the shape of your database
// Every "model" here becomes a table in PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH TABLES (required by Auth.js)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed, for email/password login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts  Account[]
  sessions  Session[]

  // CaseTube relations
  profile   CreatorProfile?
  projects  Project[]
  memory    CreatorMemory?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// CASETUBE CORE TABLES
// ============================================================

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  // Onboarding data
  country         String?
  experience      String?  // "beginner" | "existing"
  channelUrl      String?
  channelDesc     String?
  goals           String[]
  availableHours  Int?     // hours per week
  skills          String[]
  interests       String[]
  brandType       String?  // "faceless" | "personal"
  editingAbility  String?  // "none" | "basic" | "advanced"
  budget          String?  // "zero" | "low" | "medium" | "high"
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprint CreatorBlueprint?

  @@map("creator_profiles")
}

model CreatorBlueprint {
  id              String   @id @default(cuid())
  profileId       String   @unique
  niche           String   @db.Text
  targetAudience  String   @db.Text
  contentPillars  String[]
  brandVoice      String   @db.Text
  videoFormats    String[]
  postingSchedule String   @db.Text
  growthRoadmap   String   @db.Text
  monetization    String   @db.Text
  weaknesses      String   @db.Text
  advantages      String   @db.Text
  rawJson         Json?    // full AI response stored for reference
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile CreatorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("creator_blueprints")
}

// Persistent memory — the AI remembers this about the creator
model CreatorMemory {
  id             String   @id @default(cuid())
  userId         String   @unique
  brandVoice     String?  @db.Text
  targetAudience String?  @db.Text
  niche          String?
  contentPillars String[]
  products       String[]
  website        String?
  competitors    String[]
  editingStyle   String?
  thumbnailStyle String?
  preferredCta   String?
  goals          String[]
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_memory")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?       @db.Text
  stage       ProjectStage  @default(RESEARCH)
  videoTopic  String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections ProjectSection[]

  @@map("projects")
}

model ProjectSection {
  id        String      @id @default(cuid())
  projectId String
  type      SectionType
  content   Json        // flexible — stores whatever the AI generated
  version   Int         @default(1)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_sections")
}

// ============================================================
// ENUMS
// ============================================================

enum ProjectStage {
  RESEARCH
  PLANNING
  WRITING
  THUMBNAIL
  EDITING
  PUBLISHING
  ANALYSIS
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  PUBLISHED
}

enum SectionType {
  IDEAS
  HOOK
  TITLE
  SCRIPT
  DESCRIPTION
  TAGS
  THUMBNAIL
  CHAPTERS
  SHORTS
  COMMUNITY_POST
  SEO_PACKAGE
}
